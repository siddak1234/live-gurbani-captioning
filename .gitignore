# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Audio assets (downloaded, not source) — root-level only so eval_data/*/audio/
# isn't accidentally caught by the bare pattern.
/audio/
/audio_vocals/
*.wav
*.mp3
*.m4a

# OOS eval audio — gitignore raw recordings, keep GT JSONs in test/
eval_data/*/audio/*
!eval_data/*/audio/.gitkeep
eval_data/*/review/
eval_data/*/assisted_test/
diagnostics/oos_v1_assisted_crosscheck.md

# Caches
.cache/
*.banidb_cache.json
.banidb_cache.json
corpus_cache/
asr_cache/
asr_cache_vocals/
mms_cache/
training_data/
lora_adapters/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code per-developer state
.claude/settings.local.json
CLAUDE.local.md

# Secrets and credentials
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
.huggingface/
.cache/huggingface/

# Model artifacts (large, derived)
*.mlpackage/
*.mlmodelc/
*.onnx
checkpoints/
runs/
coreml_export/

# iOS — generated bundle resources (regenerated by scripts/build_ios_corpus.py)
ios/Sources/GurbaniCaptioning/Resources/shabads.json
ios/.build/
ios/.swiftpm/
ios/*.xcodeproj/xcuserdata/
ios/*.xcworkspace/xcuserdata/

      "end": 41.034049668874175,
      "line_idx": 9,
      "shabad_id": 1821,
      "verse_id": 21984,
      "banidb_gurmukhi": "ਸੁਰਿ ਨਰ ਨਾਥ ਬੇਅੰਤ ਅਜੋਨੀ ਸਾਚੈ ਮਹਲਿ ਅਪਾਰਾ ॥"
    },
    {

      "end": 38.479400662251656,
      "line_idx": 5,
      "shabad_id": 1821,
      "verse_id": 21980,
      "banidb_gurmukhi": "ਰਵਿ ਸਸਿ ਦੀਪਕ ਜਾ ਕੇ ਤ੍ਰਿਭਵਣਿ ਏਕਾ ਜੋਤਿ ਮੁਰਾਰਿ ॥"
    },

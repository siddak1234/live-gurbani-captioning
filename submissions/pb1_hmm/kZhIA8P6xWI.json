      "end": 39.988929817275746,
      "line_idx": 2,
      "shabad_id": 1821,
      "verse_id": 21977,
      "banidb_gurmukhi": "ਤਾ ਕੋ ਅੰਤੁ ਨ ਜਾਈ ਲਖਣਾ ਆਵਤ ਜਾਤ ਰਹੈ ਗੁਬਾਰਿ ॥੧॥"
    },
    {
